{
  "name": "shingo",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "content:import": "tsx scripts/import-markdown.ts",
    "content:fetch:plan": "tsx scripts/print-content-fetch-plan.ts",
    "content:nemo:plan": "tsx scripts/print-nemo-bridge-plan.ts",
    "content:import:records": "tsx scripts/import-markdown.ts --source-name shingo-records",
    "content:import:toys": "tsx scripts/import-markdown.ts --source-name shingo-toys",
    "content:import:docs": "pnpm content:import:records && pnpm content:import:toys",
    "content:import:nemo": "tsx scripts/import-markdown.ts --source-name nemo-knows-wiki --clean",
    "content:import:all": "tsx scripts/sync-content-sources.ts",
    "content:test:nemo": "tsx scripts/check-import-stability.ts",
    "content:test": "tsx scripts/check-import-stability.ts",
    "content:sync": "pnpm content:import:all && pnpm content:test && pnpm check && pnpm build",
    "content:trigger": "tsx scripts/trigger-content-update.ts",
    "content:trigger:plan": "tsx scripts/trigger-content-update.ts --dry-run",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.3.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "^6.0.3"
  }
}
