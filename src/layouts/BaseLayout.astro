---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteSidebar from '../components/SiteSidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site and knowledge base.' } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Shingo';
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com/Sizolity';
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <SiteHeader siteName={siteName} githubUrl={githubUrl} />
    <div class:list={['site-shell', Astro.slots.has('aside') && 'has-aside']}>
      <SiteSidebar />
      <main>
        <slot />
      </main>
      {
        Astro.slots.has('aside') && (
          <slot name="aside" />
        )
      }
    </div>
    <SiteFooter />
  </body>
</html>
