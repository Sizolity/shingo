---
import { getEntryTitle } from '../lib/content';
import { getWikiHref, getWikiStandaloneTitle, type WikiEntry } from '../lib/wiki';

interface Props {
  groups: Map<string, WikiEntry[]>;
  activeId?: string;
}

const { groups, activeId } = Astro.props;

function getStandaloneEntry(entries: WikiEntry[]): WikiEntry | undefined {
  if (entries.length !== 1) return undefined;
  return getWikiStandaloneTitle(entries[0]) ? entries[0] : undefined;
}
---

<aside class="wiki-aside">
  <p class="sidebar-label">知识库</p>
  {
    [...groups.entries()].map(([category, entries]) => {
      const standaloneEntry = getStandaloneEntry(entries);

      return (
        <section class="wiki-aside-section">
          {standaloneEntry ? (
            <ul>
              <li class={standaloneEntry.id === activeId ? 'active' : undefined}>
                <a href={getWikiHref(standaloneEntry)}>{category}</a>
              </li>
            </ul>
          ) : (
            <>
              <h2>{category}</h2>
              <ul>
                {entries.map((entry) => (
                  <li class={entry.id === activeId ? 'active' : undefined}>
                    <a href={getWikiHref(entry)}>{getEntryTitle(entry)}</a>
                  </li>
                ))}
              </ul>
            </>
          )}
        </section>
      );
    })
  }
</aside>
