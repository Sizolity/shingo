---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntryTitle, isPublished, sortByDateDesc } from '../../lib/content';

const projects = sortByDateDesc((await getCollection('projects')).filter(isPublished));
---

<BaseLayout title="项目" description="Personal project showcase.">
  <section class="hero">
    <h1>项目</h1>
    <p>个人项目可以用 Markdown 描述，后续也方便和 nemo-knows 做关联。</p>
  </section>

  <div class="grid">
    {
      projects.map((project) => (
        <a class="card" href={`/projects/${project.id}/`}>
          <p class="meta">{project.data.status ?? 'active'}</p>
          <h2>{getEntryTitle(project)}</h2>
          {project.data.summary && <p>{project.data.summary}</p>}
          {project.data.tags.length > 0 && (
            <p class="tags">{project.data.tags.map((tag) => <span>#{tag}</span>)}</p>
          )}
        </a>
      ))
    }
  </div>
</BaseLayout>
