---
import { getCollection, render } from 'astro:content';
import WikiAside from '../../components/WikiAside.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isPublished } from '../../lib/content';
import { getWikiDisplayTitle, groupWikiEntries, sortWikiEntries } from '../../lib/wiki';

const entries = sortWikiEntries((await getCollection('wiki')).filter(isPublished));
const groups = groupWikiEntries(entries);
const indexEntry = entries.find((entry) => entry.data.kind === 'index');
const renderedIndex = indexEntry ? await render(indexEntry) : undefined;
const IndexContent = renderedIndex?.Content;
---

<BaseLayout title={indexEntry ? getWikiDisplayTitle(indexEntry) : 'Wiki'} description="Knowledge wiki and reference notes.">
  <article class:list={['article', indexEntry && 'article--standalone-wiki']}>
    <p class="muted">Knowledge Base</p>
    <h1 class="wiki-public-title">{indexEntry ? getWikiDisplayTitle(indexEntry) : 'Wiki'}</h1>
    {IndexContent ? <IndexContent /> : <p>这里汇总文章和资料沉淀后的知识页面。</p>}
  </article>

  <WikiAside slot="aside" groups={groups} activeId={indexEntry?.id} />
</BaseLayout>
