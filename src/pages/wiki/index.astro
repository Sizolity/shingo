---
import { getCollection } from 'astro:content';
import WikiAside from '../../components/WikiAside.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isPublished } from '../../lib/content';
import { groupWikiEntries, sortWikiEntries } from '../../lib/wiki';

const entries = sortWikiEntries((await getCollection('wiki')).filter(isPublished));
const groups = groupWikiEntries(entries);
---

<BaseLayout title="Wiki" description="Knowledge wiki and reference notes.">
  <section class="hero">
    <p class="muted">Knowledge Base</p>
    <h1>Wiki</h1>
    <p>
      这里是文章自动入库后的知识库展示层。nemo-knows 作为独立后端服务负责 ingest、维护和关联，
      Shingo 负责呈现处理后的知识页面。
    </p>
  </section>

  <section class="wiki-overview">
    <p class="meta">{entries.length} 个页面</p>
    <p>
      右侧目录按 nemo-knows 的知识结构分组。后续接入独立后端服务后，这里会继续作为 Shingo 内的知识库入口。
    </p>
  </section>

  <WikiAside slot="aside" groups={groups} />
</BaseLayout>
