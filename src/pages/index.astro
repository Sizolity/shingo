---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, getEntryDate, getEntryTitle, isPublished, sortByDateDesc } from '../lib/content';

const posts = sortByDateDesc((await getCollection('posts')).filter(isPublished)).slice(0, 3);
const projects = sortByDateDesc((await getCollection('projects')).filter(isPublished)).slice(0, 3);
---

<BaseLayout title="Shingo" description="Personal website, notes, docs, and projects.">
  <section class="hero">
    <p class="muted">Personal website</p>
    <h1>记录文章、文档和个人项目。</h1>
    <p>
      这里先保持朴素：Markdown 写内容，Astro 静态渲染，后续再接入 LLM
      做标签、摘要和内容组织。
    </p>
  </section>

  <section>
    <h2>最近文章</h2>
    <div class="grid">
      {
        posts.map((post) => (
          <a class="card" href={`/posts/${post.id}/`}>
            <p class="meta">{formatDate(getEntryDate(post))}</p>
            <h3>{getEntryTitle(post)}</h3>
            {post.data.summary && <p>{post.data.summary}</p>}
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>项目展示</h2>
    <div class="grid">
      {
        projects.map((project) => (
          <a class="card" href={`/projects/${project.id}/`}>
            <p class="meta">{project.data.status ?? 'active'}</p>
            <h3>{getEntryTitle(project)}</h3>
            {project.data.summary && <p>{project.data.summary}</p>}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
