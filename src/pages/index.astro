---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, getEntryDate, getEntryTitle, isPublished, sortByDateDesc } from '../lib/content';

const records = sortByDateDesc((await getCollection('record')).filter(isPublished)).slice(0, 3);
const toys = sortByDateDesc((await getCollection('toy')).filter(isPublished)).slice(0, 3);
---

<BaseLayout title="Shingo" description="Personal website, records, wiki, and toys.">
  <section class="hero">
    <p class="muted">Personal website</p>
    <h1>记录、Wiki 和玩具项目。</h1>
    <p>
      这里先保持朴素：Markdown 写内容，Astro 静态渲染，后续再接入 LLM
      做标签、摘要和内容组织。
    </p>
  </section>

  <section>
    <h2>最近记录</h2>
    <div class="entry-list">
      {
        records.map((record) => (
          <a class="entry-card" href={`/record/${record.id}/`}>
            <p class="meta">{formatDate(getEntryDate(record))}</p>
            <h3>{getEntryTitle(record)}</h3>
            {record.data.summary && <p>{record.data.summary}</p>}
            {record.data.tags.length > 0 && (
              <p class="tags">{record.data.tags.map((tag) => <span>#{tag}</span>)}</p>
            )}
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>玩具项目</h2>
    <div class="grid">
      {
        toys.map((toy) => (
          <a class="card" href={`/toy/${toy.id}/`}>
            <p class="meta">{toy.data.status ?? 'active'}</p>
            <h3>{getEntryTitle(toy)}</h3>
            {toy.data.summary && <p>{toy.data.summary}</p>}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
